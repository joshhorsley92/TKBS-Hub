# Copy to .env.local (gitignored) and fill in.
#
# ── Supabase (the Hub's OWN project — not the CRM/Dashboard project) ─────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── GitHub sync ───────────────────────────────────────────────────────────────
# Classic PAT with `repo` read on joshhorsley92; must also read tkbs-support
# org repos (verify org access). Fallback: set both, keyed per owner.
GITHUB_PAT=

# ── FreshBooks (Phase 2) ─────────────────────────────────────────────────────
# App registered at https://my.freshbooks.com/#/developer
# Redirect URI (dev): http://localhost:3000/api/freshbooks/callback
FRESHBOOKS_CLIENT_ID=
FRESHBOOKS_CLIENT_SECRET=

# ── Sync route guard (lets a future cron caller hit /api/sync/* headlessly) ──
SYNC_SECRET=
